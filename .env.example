# Copy to .env or .bashrc/.zshrc and fill in. Source via direnv / your shell.

# Cloudflare R2 credentials for `python -m hal.scripts.fetch` (S3-compatible AWS_* names).
AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=hal

# Optional path overrides — defaults point at <repo>/fixtures/ once you fetch.
# HAL_ISO_PATH=...
# HAL_EMULATOR_PATH=...
# HAL_DEV_ARCHIVE=...
# HAL_DEV_MDS_DIR=...
