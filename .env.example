# Copy to .env (already gitignored) and fill in. Source via direnv / your shell.

# Cloudflare R2 credentials for `python -m hal.scripts.fetch`.
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hal-fixtures

# Optional path overrides — defaults point at <repo>/fixtures/ once you fetch.
# HAL_ISO_PATH=...
# HAL_EMULATOR_PATH=...
# HAL_DEV_ARCHIVE=...
# HAL_DEV_MDS_DIR=...
